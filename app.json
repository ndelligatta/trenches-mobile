{
  "expo": {
    "name": "Trenches",
    "slug": "trenches-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "trenches",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trenchesgame"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a14"
      },
      "package": "com.trenchesgame",
      "versionCode": 3,
      "privacyPolicy": "https://trenchesgame.com/privacy.html",
      "termsOfService": "https://trenchesgame.com/terms.html"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ]
  }
}
